APP_NAME=inVision U Candidate Selection System
APP_DESCRIPTION=Backend API for candidate intake, scoring pipeline, and reviewer dashboard.
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
API_V1_PREFIX=/api/v1
API_KEY=

