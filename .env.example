APP_ENV=development
APP_DEBUG=false
API_KEY=replace_with_long_random_reviewer_api_key
DEFAULT_REVIEWER_ID=reviewer_api_client
REVIEWER_API_KEYS_JSON=
PII_ENCRYPTION_KEY=replace_with_32_plus_char_random_pii_secret
AUDIT_SIGNING_KEY=
POSTGRES_DB=invisionu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_database_password
PIPELINE_QUEUE_BACKEND=redis
PIPELINE_QUEUE_NAME=invisionu:pipeline:jobs
REDIS_URL=redis://redis:6379/0
PIPELINE_WORKER_POLL_TIMEOUT_SECONDS=1
SUBMIT_RATE_LIMIT_PER_MINUTE=60
BATCH_RATE_LIMIT_PER_MINUTE=10
REVIEWER_RATE_LIMIT_PER_MINUTE=120

GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
JINA_API_KEY=your_jina_api_key_here

M5_LLM_MODEL=gemini-2.5-flash
M7_LLM_MODEL=gemini-3.1-flash-lite-preview
M13_ASR_MODEL=whisper-large-v3-turbo
EMBEDDING_MODEL=jina-embeddings-v5
EMBEDDING_FALLBACK_MODEL=BAAI/bge-m3
